# Copy to .env only to override. Dev/test fall back to the local Docker Compose stack, so a bare checkout
# boots with zero config; in production every value below is required.

# Postgres connection string used by the API (the only database client).
DATABASE_URL=postgres://viraloderegal:viraloderegal@localhost:5432/viraloderegal

# HTTP port and the directory holding the built SPA the API serves in production.
PORT=3000
WEB_DIST_DIR=../web/dist

# Phase 2 secrets. Optional today so the bare /health API boots without them.
YOUTUBE_API_KEY=
BETTER_AUTH_SECRET=

# SMTP credentials for admin invitation emails (Phase 2).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
